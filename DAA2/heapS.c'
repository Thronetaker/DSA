

void adjust(a,i,n){
    // i is parent             j is left child
    j = 2*i;
    item = a[i];
    while( j<=n && a[j]< a[j+1]){
        j++;

        if(item > a[j]) break ;

        a[j/2] = a[j];   
        j= 2*j;
    }

    a[j/2] = item;

}
void heapS(){
    heapify(a,i,n);

    for(int i = n ; i<=1 ;i++){
        int temp = a[n];
        a[n] = a[1];
        a[1] = temp ;

        adjust(a,0,i-1);
    }
}




